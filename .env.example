# Shared Connected App credentials (server-side only, never exposed to client)
# Set these in Railway / your hosting provider's env vars dashboard.
SF_CLIENT_ID=your_consumer_key_here
SF_CLIENT_SECRET=your_consumer_secret_here

# Your deployed app URL — used to build the OAuth callback redirect_uri.
# Must match exactly what's registered in the Connected App callback URLs.
# Development:  APP_URL=http://localhost:3001
# Production:   APP_URL=https://your-railway-domain.up.railway.app
APP_URL=http://localhost:3001
