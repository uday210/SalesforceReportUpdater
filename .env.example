# Shared Connected App credentials (server-side only, never exposed to client)
# Set these in Railway / your hosting provider's env vars dashboard.
SF_CLIENT_ID=your_consumer_key_here
SF_CLIENT_SECRET=your_consumer_secret_here

# The callback URL to register in your Salesforce Connected App OAuth settings:
# Development:  http://localhost:3000/api/auth/callback
# Production:   https://your-railway-domain.up.railway.app/api/auth/callback
